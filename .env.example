TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Thu muc session active/inactive (tuong thich SESSION_DIR cu).
SESSION_FOLDER=C:\tool\session
INACTIVE_SESSION_FOLDER=C:\tool\session_khong_hoat_dong

# SQLite mac dinh; production co the dung PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:///runtime/db.sqlite3

# Celery / Redis (health check broker).
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Session lock (cross-process).
TG_SESSION_LOCK_TIMEOUT=180
TG_SESSION_LOCK_STALE_SECONDS=1800