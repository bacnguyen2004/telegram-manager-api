# Lay tu https://my.telegram.org/apps
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Thu muc se chua file .session sau khi dang nhap qua API.
SESSION_FOLDER=C:\tool\telegram-manager-api\runtime\sessions

# Session lock (cross-process) — optional.
TG_SESSION_LOCK_TIMEOUT=180
TG_SESSION_LOCK_STALE_SECONDS=1800