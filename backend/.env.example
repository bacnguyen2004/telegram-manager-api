# Lay tu https://my.telegram.org/apps
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Thu muc se chua file .session sau khi dang nhap qua API.
SESSION_FOLDER=runtime/sessions

# Session lock — tranh 2 request cung luc tren 1 .session
# SESSION_LOCK_DIR=runtime/locks
# TG_SESSION_LOCK_TIMEOUT=120
# TG_SESSION_LOCK_STALE_SECONDS=300

# =============================================================================
# DATABASE — chon 1 trong 3 cach (chi can sua khi muon doi khoi mac dinh)
# =============================================================================
#
# [A] Local API + SQLite (MAC DINH — khong can dong nao ben duoi)
#     Bo trong DATABASE_URL. File: runtime/telegram_manager.db
#
# [B] Local API + PostgreSQL (uvicorn chay ngoai Docker)
#     1) Chay Postgres:  docker compose up db -d   (tu repo root)
#     2) Bat dong ben duoi:
# DATABASE_URL=postgresql+psycopg2://telegram:telegram@127.0.0.1:5433/telegram_manager
# DATABASE_ENABLED=true
#
# [C] Full Docker (api + web + db cung luc)
#     docker compose up --build
#     Khong can khai bao DATABASE_URL trong .env — compose tu inject cho service api.
#
# Tat metadata DB (chi dung file .session, khong ghi audit/login vao DB):
# DATABASE_ENABLED=false